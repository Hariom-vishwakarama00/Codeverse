<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CodeSchool – Learn Every Programming Language</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,700;0,900;1,300&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#06060a; --surface:#0f0f18; --surface2:#16161f;
  --border:rgba(255,255,255,0.07); --text:#e8e8f0; --muted:#6b6b85;
  --accent:#00e5a0; --accent2:#ff6b4a; --accent3:#4a9eff; --yellow:#f5d76e;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif;overflow-x:hidden;cursor:none}

/* ── Cursor ── */
#cur{position:fixed;width:12px;height:12px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform .15s,background .2s}
#cur-ring{position:fixed;width:36px;height:36px;border:1.5px solid rgba(0,229,160,.4);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:border-color .2s}

/* Noise */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");pointer-events:none;z-index:9990;opacity:.35}

/* ── Nav ── */
nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:18px 60px;background:rgba(6,6,10,.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);animation:slideDown .8s cubic-bezier(.17,.67,.42,.99) both}
@keyframes slideDown{from{transform:translateY(-100%);opacity:0}to{transform:translateY(0);opacity:1}}
.logo{font-family:'Fraunces',serif;font-weight:900;font-size:22px;color:#fff;text-decoration:none}
.logo span{color:var(--accent)}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{text-decoration:none;color:var(--muted);font-size:14px;transition:color .2s}
.nav-links a:hover{color:var(--text)}
.nav-cta{background:var(--accent);color:#000;font-weight:700;font-size:13px;padding:10px 22px;border-radius:100px;text-decoration:none;transition:transform .2s,box-shadow .2s;display:inline-block}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,229,160,.35)}

/* ── Hero ── */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:130px 40px 80px;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% -10%,rgba(0,229,160,.12) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 80% 60%,rgba(74,158,255,.07) 0%,transparent 60%),radial-gradient(ellipse 30% 30% at 20% 70%,rgba(255,107,74,.06) 0%,transparent 60%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 30%,transparent 100%)}
.orb{position:absolute;border-radius:50%;filter:blur(60px);opacity:.22;animation:floatOrb 8s ease-in-out infinite}
.orb1{width:320px;height:320px;background:var(--accent);top:-80px;left:8%;animation-delay:0s}
.orb2{width:220px;height:220px;background:var(--accent3);top:28%;right:4%;animation-delay:-3s}
.orb3{width:160px;height:160px;background:var(--accent2);bottom:8%;left:28%;animation-delay:-5s}
@keyframes floatOrb{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-28px) scale(1.05)}}
.hcf{position:absolute;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 18px;font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);line-height:1.9;opacity:0;animation:fadeUp .9s forwards,softFloat 7s ease-in-out infinite}
.hcf:nth-child(1){left:2%;top:22%;animation-delay:1.3s,0s}
.hcf:nth-child(2){right:2%;top:32%;animation-delay:1.6s,-2.5s}
@keyframes softFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
.hero-eyebrow{font-family:'DM Mono',monospace;font-size:12px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:24px;opacity:0;animation:fadeUp .8s .3s forwards;position:relative;z-index:1}
.hero h1{font-family:'Fraunces',serif;font-weight:900;font-size:clamp(52px,8vw,100px);line-height:.95;letter-spacing:-3px;color:#fff;max-width:900px;opacity:0;animation:fadeUp .8s .5s forwards;position:relative;z-index:1}
.hero h1 em{font-style:italic;color:var(--accent)}
.hero-sub{font-size:17px;color:var(--muted);max-width:520px;line-height:1.7;margin-top:24px;font-weight:300;opacity:0;animation:fadeUp .8s .7s forwards;position:relative;z-index:1}
.hero-actions{display:flex;gap:16px;margin-top:44px;opacity:0;animation:fadeUp .8s .9s forwards;position:relative;z-index:1}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
.btn-primary{background:var(--accent);color:#000;font-weight:700;font-size:15px;padding:16px 36px;border-radius:100px;text-decoration:none;transition:transform .2s,box-shadow .2s;display:inline-block}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,229,160,.4)}
.btn-ghost{border:1px solid var(--border);color:var(--text);font-size:15px;padding:16px 36px;border-radius:100px;text-decoration:none;transition:border-color .2s,background .2s;display:inline-block}
.btn-ghost:hover{border-color:rgba(255,255,255,.25);background:rgba(255,255,255,.04)}
.scroll-hint{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fadeUp .8s 1.5s forwards;z-index:1}
.scroll-line{width:1px;height:50px;background:linear-gradient(to bottom,transparent,var(--muted));animation:scrollPulse 2s ease-in-out infinite}
@keyframes scrollPulse{0%,100%{opacity:.3;height:50px}50%{opacity:1;height:68px}}
.scroll-hint span{font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;font-family:'DM Mono',monospace}

/* ── Stats ── */
.stats{display:flex;border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--surface)}
.stat{flex:1;text-align:center;padding:40px 16px;border-right:1px solid var(--border);transition:background .3s}
.stat:last-child{border-right:none}
.stat:hover{background:var(--surface2)}
.stat-num{font-family:'Fraunces',serif;font-size:48px;font-weight:900;color:#fff;line-height:1}
.stat-num span{color:var(--accent)}
.stat-lbl{font-size:13px;color:var(--muted);margin-top:6px;letter-spacing:.5px}

/* ── Sections ── */
section{padding:100px 60px}
.eyebrow{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:16px}
.sec-title{font-family:'Fraunces',serif;font-size:clamp(34px,4vw,54px);font-weight:900;line-height:1.05;letter-spacing:-1.5px;color:#fff}
.sec-title em{font-style:italic;color:var(--accent2)}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s cubic-bezier(.17,.67,.42,.99)}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── Lang Cards ── */
.langs-section{background:var(--bg)}
.langs-header{max-width:600px;margin-bottom:52px}
.langs-desc{color:var(--muted);font-size:16px;line-height:1.7;margin-top:16px;font-weight:300}
.search-wrap{position:relative;margin-bottom:16px;max-width:360px}
.search-wrap input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:100px;padding:10px 18px 10px 42px;font-family:'Outfit',sans-serif;font-size:14px;color:var(--text);outline:none;transition:border-color .2s}
.search-wrap input:focus{border-color:rgba(255,255,255,.25)}
.search-wrap input::placeholder{color:var(--muted)}
.search-icon{position:absolute;left:16px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:14px;pointer-events:none}
.filters{display:flex;gap:10px;margin-bottom:36px;flex-wrap:wrap}
.f-btn{background:none;border:1px solid var(--border);color:var(--muted);font-family:'Outfit',sans-serif;font-size:13px;padding:8px 18px;border-radius:100px;cursor:none;transition:all .2s}
.f-btn:hover,.f-btn.active{background:var(--accent);border-color:var(--accent);color:#000;font-weight:600}
.langs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px}
.lang-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:14px;position:relative;overflow:hidden;opacity:0;transform:translateY(24px);transition:opacity .45s ease,transform .45s cubic-bezier(.17,.67,.42,.99),border-color .3s,box-shadow .3s;cursor:none}
.lang-card.visible{opacity:1;transform:translateY(0)}
.lang-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--cc,transparent) 0%,transparent 60%);opacity:.06;transition:opacity .3s;pointer-events:none}
.lang-card:hover::before{opacity:.13}
.lang-card:hover{transform:translateY(-6px) !important;border-color:var(--cc,var(--border));box-shadow:0 20px 60px rgba(0,0,0,.4),0 0 0 1px var(--cc,transparent)}
.lang-top{display:flex;align-items:center;justify-content:space-between}
.lang-icon{width:52px;height:52px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:26px;background:rgba(255,255,255,.05)}
.lang-badge{font-family:'DM Mono',monospace;font-size:10px;padding:4px 10px;border-radius:100px;letter-spacing:1px;text-transform:uppercase}
.b-beginner{background:rgba(0,229,160,.12);color:var(--accent)}
.b-intermediate{background:rgba(245,215,110,.12);color:var(--yellow)}
.b-advanced{background:rgba(255,107,74,.12);color:var(--accent2)}
.lang-name{font-family:'Fraunces',serif;font-size:22px;font-weight:700;color:#fff}
.lang-tag{font-size:13px;color:var(--muted);line-height:1.6;font-weight:300}
.lang-bar{height:3px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden}
.lang-fill{height:100%;border-radius:2px;width:0%;transition:width 1.3s cubic-bezier(.17,.67,.42,.99)}
.lang-meta{display:flex;gap:16px;margin-top:auto;padding-top:16px;border-top:1px solid var(--border)}
.lm{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted)}
.lm strong{display:block;color:var(--text);font-size:14px;margin-bottom:2px}
#no-results{display:none;color:var(--muted);font-family:'DM Mono',monospace;font-size:14px;text-align:center;padding:40px 0}

/* ── Playground ── */
.pg-section{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.pg-inner{display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;max-width:1200px;margin:0 auto}
.pg-info p{color:var(--muted);font-size:16px;line-height:1.7;font-weight:300;margin:20px 0 28px}
.lang-tabs{display:flex;gap:8px;flex-wrap:wrap}
.ltab{background:none;border:1px solid var(--border);color:var(--muted);font-family:'DM Mono',monospace;font-size:12px;padding:7px 14px;border-radius:6px;cursor:none;transition:all .2s}
.ltab:hover,.ltab.active{background:var(--surface2);border-color:rgba(255,255,255,.25);color:var(--text)}
.code-win{background:#0a0a12;border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:0 40px 100px rgba(0,0,0,.6)}
.win-bar{display:flex;align-items:center;gap:8px;padding:14px 18px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--border)}
.dot{width:12px;height:12px;border-radius:50%}
.dot.r{background:#ff5f57}.dot.y{background:#ffbd2e}.dot.g{background:#28ca42}
.win-file{margin-left:8px;font-family:'DM Mono',monospace;font-size:12px;color:var(--muted)}
.code-body{padding:28px;font-family:'DM Mono',monospace;font-size:13px;line-height:2;min-height:290px}
.snip{display:none}.snip.active{display:block}
.ln{display:inline-block;width:28px;color:rgba(255,255,255,.12);user-select:none;font-size:11px}
.kw{color:#569cd6}.fn{color:#dcdcaa}.st{color:#ce9178}.nm{color:#b5cea8}.cm{color:#6a9955}.op{color:var(--accent)}
.out-bar{background:rgba(0,229,160,.05);border-top:1px solid rgba(0,229,160,.15);padding:14px 28px;font-family:'DM Mono',monospace;font-size:13px;color:var(--accent)}
.out-bar b{color:var(--muted);font-weight:400;margin-right:8px}

/* ── Paths ── */
.paths-section{background:var(--bg)}
.paths-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:56px}
.path-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:36px;position:relative;overflow:hidden;transition:transform .3s,box-shadow .3s}
.path-card:hover{transform:translateY(-8px);box-shadow:0 30px 80px rgba(0,0,0,.4)}
.path-num{font-family:'Fraunces',serif;font-size:80px;font-weight:900;color:rgba(255,255,255,.04);line-height:1;position:absolute;top:12px;right:20px}
.path-icon{width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:28px;margin-bottom:20px}
.path-name{font-family:'Fraunces',serif;font-size:24px;font-weight:700;color:#fff;margin-bottom:12px}
.path-desc{color:var(--muted);font-size:14px;line-height:1.7;font-weight:300}
.path-langs{display:flex;gap:8px;margin-top:24px;flex-wrap:wrap}
.pl{font-size:11px;font-family:'DM Mono',monospace;padding:4px 10px;border-radius:6px;background:rgba(255,255,255,.05);color:var(--muted);border:1px solid var(--border)}

/* ── Features ── */
.features-section{background:var(--surface)}
.feat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-top:56px}
.feat{background:var(--surface);padding:36px 28px;transition:background .3s}
.feat:hover{background:var(--surface2)}
.feat-icon{font-size:32px;margin-bottom:16px}
.feat-name{font-size:16px;font-weight:600;color:#fff;margin-bottom:10px}
.feat-desc{font-size:13px;color:var(--muted);line-height:1.6;font-weight:300}

/* ── Testimonials ── */
.testi-section{background:var(--bg)}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:56px}
.testi{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:32px;transition:transform .3s}
.testi:hover{transform:translateY(-4px)}
.testi-text{font-size:15px;color:var(--text);line-height:1.7;font-style:italic;font-family:'Fraunces',serif;font-weight:300;margin-bottom:24px}
.testi-auth{display:flex;align-items:center;gap:12px}
.avatar{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;background:var(--surface2)}
.auth-name{font-size:14px;font-weight:600;color:#fff}
.auth-role{font-size:12px;color:var(--muted);font-family:'DM Mono',monospace}
.stars{color:var(--yellow);font-size:12px;margin-bottom:16px}

/* ── CTA ── */
.cta-section{background:var(--bg);text-align:center;padding:120px 60px;position:relative;overflow:hidden}
.cta-section::before{content:'';position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(0,229,160,.1) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.cta-section .sec-title{font-size:clamp(40px,5vw,70px);margin-bottom:20px}
.cta-section p{color:var(--muted);font-size:18px;font-weight:300;max-width:500px;margin:0 auto 48px}
.cta-actions{display:flex;gap:16px;justify-content:center}

/* ── Footer ── */
footer{background:var(--surface);border-top:1px solid var(--border);padding:60px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px}
.footer-brand .logo{display:block;margin-bottom:12px;font-size:22px}
.footer-brand p{font-size:13px;color:var(--muted);line-height:1.7;font-weight:300;max-width:260px}
.fc h4{font-size:13px;font-weight:600;color:#fff;margin-bottom:16px;letter-spacing:.5px}
.fc a{display:block;font-size:13px;color:var(--muted);text-decoration:none;margin-bottom:10px;transition:color .2s}
.fc a:hover{color:var(--text)}
.footer-btm{background:var(--surface);border-top:1px solid var(--border);padding:20px 60px;display:flex;justify-content:space-between}
.footer-btm p{font-size:12px;color:var(--muted);font-family:'DM Mono',monospace}

/* ── Modal ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.78);backdrop-filter:blur(14px);z-index:800;display:flex;align-items:center;justify-content:center;padding:24px;opacity:0;pointer-events:none;transition:opacity .3s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:20px;width:100%;max-width:680px;max-height:88vh;overflow-y:auto;padding:40px;position:relative;transform:translateY(30px);transition:transform .3s}
.modal-overlay.open .modal{transform:translateY(0)}
.modal-close{position:absolute;top:18px;right:18px;background:var(--surface2);border:1px solid var(--border);color:var(--muted);font-size:16px;width:34px;height:34px;border-radius:50%;cursor:none;display:flex;align-items:center;justify-content:center;transition:color .2s,border-color .2s;line-height:1}
.modal-close:hover{color:#fff;border-color:rgba(255,255,255,.3)}
.modal-head{display:flex;align-items:center;gap:16px;margin-bottom:24px}
.modal-icon{font-size:40px}
.modal-lang-name{font-family:'Fraunces',serif;font-size:32px;font-weight:900;color:#fff;line-height:1}
.modal-desc{color:var(--muted);font-size:15px;line-height:1.8;margin-bottom:28px;font-weight:300}
.modal-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px}
.ms{background:var(--surface2);border-radius:12px;padding:16px;text-align:center}
.ms strong{display:block;font-family:'Fraunces',serif;font-size:28px;font-weight:900;color:#fff}
.ms span{font-size:12px;color:var(--muted);font-family:'DM Mono',monospace}
.modal-code{background:#0a0a12;border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:16px}
.mc-bar{padding:10px 16px;border-bottom:1px solid var(--border);font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);background:rgba(255,255,255,.02)}
.mc-body{padding:20px;font-family:'DM Mono',monospace;font-size:13px;line-height:1.9}
.modal-out{background:rgba(0,229,160,.05);border:1px solid rgba(0,229,160,.15);border-radius:8px;padding:12px 16px;font-family:'DM Mono',monospace;font-size:13px;color:var(--accent);margin-bottom:24px}
.modal-out b{color:var(--muted);font-weight:400;margin-right:8px}
.modal-topics h4{font-size:14px;font-weight:600;color:#fff;margin-bottom:12px}
.topics-list{display:flex;flex-wrap:wrap;gap:8px}
.topic{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:6px;padding:5px 12px;font-size:12px;color:var(--muted);font-family:'DM Mono',monospace}
.modal-enroll{display:block;width:100%;background:var(--accent);color:#000;font-weight:700;font-size:15px;padding:16px;border-radius:12px;text-align:center;text-decoration:none;margin-top:28px;transition:box-shadow .2s,transform .2s;border:none;cursor:none}
.modal-enroll:hover{box-shadow:0 8px 30px rgba(0,229,160,.4);transform:translateY(-2px)}

/* Scroll to top */
#stt{position:fixed;bottom:32px;right:32px;width:44px;height:44px;background:var(--accent);border:none;border-radius:50%;color:#000;font-size:18px;display:flex;align-items:center;justify-content:center;cursor:none;z-index:400;opacity:0;pointer-events:none;transition:opacity .3s,transform .2s;box-shadow:0 4px 20px rgba(0,229,160,.35)}
#stt.show{opacity:1;pointer-events:all}
#stt:hover{transform:translateY(-3px)}

/* Responsive */
@media(max-width:960px){
  nav{padding:16px 24px}
  .nav-links{display:none}
  section{padding:70px 24px}
  .pg-inner{grid-template-columns:1fr}
  .paths-grid{grid-template-columns:1fr}
  .feat-grid{grid-templ
